// ============================================
// BACKGROUND JOB QUEUE SYSTEM
// ============================================

model BackgroundJob {
  id              String            @id @default(cuid())
  tenantId        String?
  
  // Job Type & Classification
  type            JobQueueType
  name            String
  description     String?
  priority        JobPriority       @default(NORMAL)
  
  // Job Data
  input           String            // JSON encoded input data
  output          String?           // JSON encoded output data
  error           String?           // Error message if failed
  
  // Scheduling
  runAt           DateTime?         // Scheduled run time (null = immediate)
  startedAt       DateTime?         // When processing started
  completedAt     DateTime?         // When processing completed
  
  // Status & Progress
  status          JobQueueStatus    @default(PENDING)
  progress        Int               @default(0)  // 0-100 percentage
  progressMessage String?
  
  // Retry Configuration
  attempts        Int               @default(0)
  maxAttempts     Int               @default(3)
  lastAttemptAt   DateTime?
  nextRetryAt     DateTime?
  
  // Timing
  duration        Int?              // Duration in milliseconds
  
  // Context
  createdBy       String?           // User ID who created the job
  relatedType     String?           // e.g., "candidate", "job", "disc_test"
  relatedId       String?           // ID of related entity
  
  // Result
  result          String?           // JSON encoded result summary
  
  // Timestamps
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // Indexes
  @@index([status, priority])
  @@index([type, status])
  @@index([runAt])
  @@index([tenantId, status])
  @@index([relatedType, relatedId])
  @@map("background_jobs")
}

// ============================================
// JOB QUEUE ENUMS
// ============================================

enum JobQueueType {
  RESUME_PARSE
  CANDIDATE_MATCH
  BATCH_SCREENING
  SEND_EMAIL
  DISC_ANALYSIS
  WEBHOOK_DISPATCH
}

enum JobPriority {
  HIGH
  NORMAL
  LOW
}

enum JobQueueStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  RETRY
}

// ============================================
// STRIPE BILLING & SUBSCRIPTIONS
// ============================================

model Subscription {
  id                    String             @id @default(cuid())
  tenantId              String             @unique
  
  // Stripe IDs
  stripeCustomerId      String
  stripeSubscriptionId  String             @unique
  stripePriceId         String
  stripeProductId       String?
  
  // Status
  status                SubscriptionStatus @default(ACTIVE)
  
  // Billing Period
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean            @default(false)
  canceledAt            DateTime?
  
  // Trial
  trialStart            DateTime?
  trialEnd              DateTime?
  
  // Plan Info (denormalized for quick access)
  plan                  Plan
  priceAmount           Int                // in cents
  priceCurrency         String             @default("usd")
  interval              String             // month, year
  
  // Timestamps
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  
  // Relations
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([stripeCustomerId])
  @@index([status])
  @@map("subscriptions")
}

// ============================================
// SUBSCRIPTION ENUMS
