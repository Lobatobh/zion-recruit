// ============================================
// API CREDENTIALS & USAGE TRACKING
// ============================================

model ApiCredential {
  id                String           @id @default(cuid())
  tenantId          String
  
  // Provider Info
  provider          ApiProvider
  name              String
  description       String?
  
  // Credentials (encrypted)
  apiKey            String           // Encrypted API key
  apiSecret         String?          // Encrypted secret (if needed)
  endpoint          String?          // Custom endpoint URL
  organizationId    String?          // For OpenAI organization
  
  // Extra fields for different providers
  projectUrl        String?          // Supabase project URL
  projectKey        String?          // Supabase anon/service key
  region            String?          // AWS region, Cloud region
  accountId         String?          // Account ID (AWS, Azure, etc.)
  instanceName      String?          // Evolution API instance name
  webhookUrl        String?          // Webhook URL for callbacks
  
  // Configuration
  defaultModel      String?
  maxTokensPerCall  Int?
  temperature       Float?
  
  // Status
  isActive          Boolean          @default(true)
  isDefault         Boolean          @default(false)
  lastUsedAt        DateTime?
  lastErrorAt       DateTime?
  lastError         String?
  
  // Usage Limits & Alerts
  monthlyLimit      Int?             // Max tokens/calls per month
  alertThreshold    Int?             // Percentage to trigger alert (e.g., 80)
  currentUsage      Int              @default(0)
  usageResetAt      DateTime?
  
  // Timestamps
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  // Relations
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usageLogs         ApiUsageLog[]
  alerts            ApiAlert[]
  aiAgents          AIAgent[]
  
  @@unique([tenantId, provider, name])
  @@index([tenantId, provider])
  @@index([tenantId, isActive])
  @@map("api_credentials")
}

model ApiUsageLog {
  id                String           @id @default(cuid())
  tenantId          String
  credentialId      String
  
  // Request Info
  requestType       String           // e.g., "chat_completion", "embedding", "transcription"
  model             String
  provider          ApiProvider
  
  // Tokens
  promptTokens      Int              @default(0)
  completionTokens  Int              @default(0)
  totalTokens       Int              @default(0)
  
  // Cost (in USD, stored as cents to avoid floating point)
  costCents         Int              @default(0)
  
  // Performance
  durationMs        Int?             // Request duration in milliseconds
  
  // Status
  status            ApiCallStatus
  errorMessage      String?
  
  // Context
  agentType         String?          // Which AI agent made the call
  jobId             String?          // Related job (if any)
  candidateId       String?          // Related candidate (if any)
  taskId            String?          // Related AI task (if any)
  
  // Timestamps
  createdAt         DateTime         @default(now())
  
  // Relations
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  credential        ApiCredential    @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  
  @@index([tenantId, createdAt])
  @@index([credentialId, createdAt])
  @@index([provider, createdAt])
  @@map("api_usage_logs")
}

model ApiAlert {
  id                String           @id @default(cuid())
  tenantId          String
  credentialId      String
  
  // Alert Info
  type              ApiAlertType
  severity          ApiAlertSeverity
  message           String
  
  // Threshold Info
  thresholdValue    Int?             // The threshold that was crossed
  currentValue      Int?             // The current value
  
  // Status
  isRead            Boolean          @default(false)
  readAt            DateTime?
  readBy            String?          // User ID who read it
  isResolved        Boolean          @default(false)
  resolvedAt        DateTime?
  resolvedBy        String?          // User ID who resolved it
  
  // Timestamps
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  // Relations
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  credential        ApiCredential    @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  
  @@index([tenantId, isRead])
  @@index([tenantId, createdAt])
  @@map("api_alerts")
}

// ============================================
// NOTIFICATION SYSTEM
// ============================================

model Notification {
  id          String             @id @default(cuid())
  tenantId    String
  userId      String?            // Null = notification for all tenant members
  
  // Notification Type & Category
  type        NotificationType
  category    NotificationCategory
  priority    NotificationPriority @default(NORMAL)
  
  // Content
  title       String
  message     String
  description String?            // Extended description (markdown supported)
  
  // Action Link
  actionUrl   String?            // URL to navigate when clicked
  actionLabel String?            // Label for the action button
  
  // Related Entity
  entityType  String?            // e.g., "candidate", "job", "ai_task", "interview"
  entityId    String?            // ID of the related entity
  
  // Status
  isRead      Boolean            @default(false)
  readAt      DateTime?
  readBy      String?            // User ID who read it
  
  isArchived  Boolean            @default(false)
  archivedAt  DateTime?
  archivedBy  String?            // User ID who archived it
  
  isPinned    Boolean            @default(false)    // Pinned notifications stay at top
  
  // Delivery
  deliveredEmail  Boolean        @default(false)
  deliveredPush   Boolean        @default(false)
  deliveredInApp  Boolean        @default(true)
  
  // Timestamps
  expiresAt   DateTime?          // Optional expiration date
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  
  // Relations
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([tenantId, isRead])
  @@index([tenantId, createdAt])
  @@index([userId, isRead])
  @@index([category, createdAt])
  @@index([entityType, entityId])
  @@map("notifications")
}

