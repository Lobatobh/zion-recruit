// Zion Recruit - AI-Powered Recruitment SaaS
// Part of Zion Assessment Ecosystem
// Version: 2.0 - AI Agents Architecture

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// TENANCY & AUTHENTICATION
// ============================================

model Tenant {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  logo            String?
  plan            Plan     @default(FREE)
  maxJobs         Int      @default(10)
  maxMembers      Int      @default(5)
  maxCandidates   Int      @default(500)
  
  // Stripe
  stripeCustomerId String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members          TenantMember[]
  jobs             Job[]
  candidates       Candidate[]
  pipelineStages   PipelineStage[]
  aiAgents         AIAgent[]
  aiTasks          AITask[]
  discTests        DISCTest[]
  messageChannels  MessageChannel[]
  conversations    Conversation[]
  messageTemplates MessageTemplate[]
  interviews       Interview[]
  apiCredentials   ApiCredential[]
  apiUsageLogs     ApiUsageLog[]
  apiAlerts        ApiAlert[]
  notifications    Notification[]
  subscription     Subscription?
  webhooks         Webhook[]
  auditLogs        AuditLog[]
  clients          Client[]
  trackingEvents   TrackingEvent[]
  trackingNotifs   TrackingNotification[]
  campaigns        Campaign[]
  automations      Automation[]

  @@map("tenants")
}

model TenantMember {
  id             String     @id @default(cuid())
  tenantId       String
  userId         String
  role           MemberRole @default(RECRUITER)
  joinedAt       DateTime   @default(now())
  
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@map("tenant_members")
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  image         String?
  password      String?
  emailVerified DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  accounts      Account[]
  sessions      Session[]
  memberships   TenantMember[]
  notifications Notification[]
  auditLogs     AuditLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// AI AGENTS SYSTEM
// ============================================

model AIAgent {
  id               String      @id @default(cuid())
  tenantId         String
  
  type             AgentType
  name             String
  description      String?
  
  config           String?
  prompts          String?
  model            String?     @default("gpt-4o-mini")
  maxTokens        Int?        @default(2000)
  temperature      Float?      @default(0.3)
  
  status           AgentStatus @default(IDLE)
  lastRunAt        DateTime?
  nextRunAt        DateTime?
  
  totalRuns        Int         @default(0)
  successCount     Int         @default(0)
  errorCount       Int         @default(0)
  totalTokensUsed  Int         @default(0)
  
  schedule         String?
  enabled          Boolean     @default(true)
  autoRun          Boolean     @default(false)
  
  credentialId      String?
  
  lastError        String?
  lastErrorAt      DateTime?
  
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  credential       ApiCredential?     @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  tasks            AITask[]

  @@unique([tenantId, type])
  @@map("ai_agents")
}

model AITask {
  id              String      @id @default(cuid())
  tenantId        String
  agentId         String
  
  type            String
  status          TaskStatus  @default(PENDING)
  priority        Int         @default(5)
  
  input           String
  output          String?
  error           String?
  
  startedAt       DateTime?
  completedAt     DateTime?
  duration        Int?
  
  tokensUsed      Int?
  modelUsed       String?
  
  jobId           String?
  candidateId     String?
  
  attempts        Int         @default(0)
  maxAttempts     Int         @default(3)
  
  requiresReview  Boolean     @default(false)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent           AIAgent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([status, priority])
  @@map("ai_tasks")
}

// ============================================
// JOBS & RECRUITMENT
// ============================================

model Job {
  id                  String        @id @default(cuid())
  tenantId            String
  
  title               String
  slug                String
  department          String?
  description         String
  requirements        String
  benefits            String?
  
  type                JobType       @default(FULL_TIME)
  contractType        ContractType? @default(CLT)
  workModel           WorkModel?    @default(REMOTE)
  
  location            String?
  city                String?
  state               String?
  country             String?       @default("Brasil")
  remote              Boolean       @default(false)
  
  salaryMin           Int?
  salaryMax           Int?
  salaryType          SalaryType?   @default(MONTHLY)
  currency            String        @default("BRL")
  
  aiParsedSkills      String?
  aiParsedKeywords    String?
  aiParsedSeniority   String?
  aiSummary           String?
  
  discProfileRequired String?
  
  status              JobStatus     @default(DRAFT)
  publishedAt         DateTime?
  expiresAt           DateTime?
  
  // Public job board fields
  isPublic            Boolean       @default(false)
  publicSlug          String?       @unique  // SEO-friendly URL for public job board
  
  viewsCount          Int           @default(0)
  applicationsCount   Int           @default(0)
  
  sourcingEnabled     Boolean       @default(false)
  sourcingLastRun     DateTime?
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  clientId            String?
  
  tenant              Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client              Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  candidates          Candidate[]
  conversations       Conversation[]
  interviews          Interview[]
  trackingEvents      TrackingEvent[]
  campaigns           Campaign[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@map("jobs")
}

model Candidate {
  id                  String          @id @default(cuid())
  tenantId            String
  jobId               String?
  pipelineStageId     String?
  
  name                String
  email               String
  phone               String?
  
  linkedin            String?
  github              String?
  portfolio           String?
  
  resumeUrl           String?
  resumeText          String?
  photo               String?
  
  parsedSkills        String?
  parsedExperience    String?
  parsedEducation     String?
  aiSummary           String?
  
  city                String?
  state               String?
  country             String?         @default("Brasil")
  
  matchScore          Int?
  matchDetails        String?
  skillsScore         Int?
  experienceScore     Int?
  
  source              String?
  sourceUrl           String?
  sourcedBy           String?
  
  status              CandidateStatus @default(SOURCED)
  
  contactedAt         DateTime?
  respondedAt         DateTime?
  responseStatus      ResponseStatus?
  
  interviewStatus     InterviewStatus?
  interviewAt         DateTime?
  interviewNotes      String?
  
  discTestSentAt      DateTime?
  discTestCompletedAt DateTime?
  
  // Portal access
  candidateToken      String?         @unique  // For portal access
  
  notes               Note[]
  feedback            String?
  rating              Int?
  
  tags                String?
  
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  tenant              Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job                 Job?            @relation(fields: [jobId], references: [id], onDelete: SetNull)
  pipelineStage       PipelineStage?  @relation(fields: [pipelineStageId], references: [id], onDelete: SetNull)
  discTests           DISCTest[]
  conversations       Conversation[]
  interviews          Interview[]
  trackingEvents      TrackingEvent[]
  portalAccess        CandidatePortalAccess?
  stageHistory        CandidateStageHistory[]

  @@index([tenantId, jobId])
  @@index([tenantId, status])
  @@index([tenantId, email])
  @@map("candidates")
}

// ============================================
// CANDIDATE STAGE HISTORY
// Tracks stage changes for candidate portal transparency
// ============================================

model CandidateStageHistory {
  id              String   @id @default(cuid())
  candidateId     String
  tenantId        String
  
  fromStageId     String?
  fromStageName   String?
  
  toStageId       String?
  toStageName     String?
  
  status          CandidateStatus @default(SOURCED)
  
  changedById     String?   // User who made the change
  changedByName   String?   // Denormalized for display
  
  note            String?   // Optional note about the change
  isReverted      Boolean   @default(false)
  
  createdAt       DateTime  @default(now())

  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt])
  @@index([tenantId, candidateId])
  @@map("candidate_stage_history")
}

// ============================================
// CANDIDATE PORTAL ACCESS
// ============================================

model CandidatePortalAccess {
  id              String    @id @default(cuid())
  candidateId     String    @unique
  
  token           String    @unique  // Secure token for magic link auth
  expiresAt       DateTime
  lastAccessAt    DateTime?
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([candidateId])
  @@map("candidate_portal_access")
}

model PipelineStage {
  id              String      @id @default(cuid())
  tenantId        String
  name            String
  order           Int
  color           String      @default("#6B7280")
  isDefault       Boolean     @default(false)
  isHired         Boolean     @default(false)
  isRejected      Boolean     @default(false)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidates      Candidate[]

  @@unique([tenantId, name])
  @@map("pipeline_stages")
}

model Note {
  id          String   @id @default(cuid())
  candidateId String
  content     String
  type        NoteType @default(GENERAL)
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("notes")
}

// ============================================
// INTERVIEWS SYSTEM
// ============================================

model Interview {
  id              String            @id @default(cuid())
  tenantId        String
  candidateId     String
  jobId           String
  
  // Interview Details
  title           String
  type            InterviewType     @default(SCREENING)
  description     String?
  
  // Scheduling
  scheduledAt     DateTime
  duration        Int               @default(60) // in minutes
  timezone        String            @default("America/Sao_Paulo")
  location        String?           // Physical location
  meetingUrl      String?           // Video call URL
  meetingProvider String?           // zoom, meet, teams, etc.
  
  // Status
  status          InterviewStatus   @default(SCHEDULED)
  confirmedAt     DateTime?
  confirmedBy     String?           // User ID who confirmed
  cancelledAt     DateTime?
  cancelledBy     String?           // User ID who cancelled
  cancelReason    String?
  completedAt     DateTime?
  noShowAt        DateTime?
  
  // Assignment
  interviewerId   String?           // User ID of interviewer
  interviewerName String?           // Denormalized for display
  
  // AI Generated
  scheduledByAI   Boolean           @default(false)
  aiAgentId       String?           // Agent that scheduled
  
  // Feedback & Evaluation
  feedback        String?
  rating          Int?              // 1-5 stars
  recommendation  String?           // hire, no_hire, maybe
  strengths       String?           // JSON array
  weaknesses      String?           // JSON array
  followUpNotes   String?
  
  // Reminders
  reminderSentAt  DateTime?
  reminderType    String?           // email, whatsapp, both
  
  // Timestamps
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate       Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job             Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([tenantId, scheduledAt])
  @@index([tenantId, status])
  @@index([candidateId])
  @@index([jobId])
  @@index([interviewerId])
  @@map("interviews")
}

// ============================================
// DISC ASSESSMENT SYSTEM
// ============================================

model DISCTest {
  id                String        @id @default(cuid())
  tenantId          String
  candidateId       String
  
  status            DISCStatus    @default(PENDING)
  sentAt            DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  
  profileD          Int?
  profileI          Int?
  profileS          Int?
  profileC          Int?
  
  primaryProfile    String?
  secondaryProfile  String?
  profileCombo      String?
  
  graphI            String?
  graphII           String?
  graphIII          String?
  
  aiAnalysis        String?
  aiStrengths       String?
  aiWeaknesses      String?
  aiWorkStyle       String?
  
  jobFitScore       Int?
  jobFitDetails     String?
  
  answers           DISCAnswer[]
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate         Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([candidateId])
  @@map("disc_tests")
}

// ============================================
// CLIENT COMPANY TRACKING SYSTEM
// ============================================

model Client {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  logo        String?

  // CNPJ & Corporate data (from BrasilAPI)
  cnpj            String?   @unique
  tradeName       String?
  legalNature     String?
  foundingDate    String?
  companySize     String?
  shareCapital    String?
  registration    String?   // Inscrição Estadual
  companyEmail    String?
  companyPhone    String?
  mainActivity    String?
  status          String?   // Situação cadastral

  // Address (from CEP lookup)
  cep             String?
  street          String?
  number          String?
  complement      String?
  neighborhood    String?
  city            String?
  state           String?
  address         String?

  // Extra info
  industry     String?
  website      String?
  notes        String?

  // Primary contact (manual)
  contactName  String?
  contactEmail String?
  contactPhone String?

  // Notification preferences
  notifyEmail      Boolean          @default(false)
  notifyWhatsapp   Boolean          @default(false)
  notifyFrequency  NotifyFrequency  @default(IMMEDIATE)
  notifyEvents     String           @default("[]") // JSON array of TrackingEventType
  aiTone           String           @default("professional") // professional, casual, formal

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobs         Job[]
  contacts     ClientContact[]
  events       TrackingEvent[]
  notifications TrackingNotification[]

  @@unique([tenantId, slug])
  @@map("clients")
}

model ClientContact {
  id          String   @id @default(cuid())
  clientId    String
  name        String
  email       String?
  phone       String?
  role        String?
  isPrimary   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  notifications TrackingNotification[]

  @@map("client_contacts")
}

model TrackingEvent {
  id          String             @id @default(cuid())
  tenantId    String
  clientId    String
  jobId       String?
  candidateId String?
  
  type        TrackingEventType
  title       String
  description String?
  metadata    String?
  
  isRead      Boolean            @default(false)
  createdAt   DateTime           @default(now())

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client       Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  job          Job?                @relation(fields: [jobId], references: [id], onDelete: SetNull)
  candidate    Candidate?          @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  notifications TrackingNotification[]

  @@index([tenantId, clientId, createdAt])
  @@map("tracking_events")
}

model TrackingNotification {
  id          String               @id @default(cuid())
  tenantId    String
  clientId    String
  eventId     String
  contactId   String?
  
  channel     NotifyChannel        @default(EMAIL)
  status      TrackingNotifStatus  @default(PENDING)
  
  message     String
  subject     String?
  aiGenerated Boolean              @default(true)
  
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  error       String?
  
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client       Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  event        TrackingEvent       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  contact      ClientContact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([tenantId, clientId, createdAt])
  @@map("tracking_notifications")
}

model DISCAnswer {
  id              String   @id @default(cuid())
  testId          String
  questionNumber  Int
  
  mostOption      String
  leastOption     String
  
  createdAt       DateTime @default(now())

  test            DISCTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, questionNumber])
  @@map("disc_answers")
}

// ============================================
// AI CACHE (for caching parsed resumes, match scores, etc.)
// ============================================

model AICache {
  id         String   @id @default(cuid())
  cacheKey   String   @unique
  cacheType  String   // resume_parse, match_score, summary
  tenantId   String
  inputData  String
  outputData String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId, cacheType])
  @@index([expiresAt])
  @@map("ai_cache")
}

// ============================================
// ENUMS
// ============================================

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum MemberRole {
  OWNER
  ADMIN
  RECRUITER
  VIEWER
}

enum AgentType {
  JOB_PARSER
  SOURCING
  SCREENING
  CONTACT
  SCHEDULER
  DISC_ANALYZER
  MATCHING
  REPORT
  ORCHESTRATOR
}

enum AgentStatus {
  IDLE
  RUNNING
  PAUSED
  ERROR
  DISABLED
}

enum TaskStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  RETRY
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum ContractType {
  CLT
  PJ
  CONTRACTOR
  INTERNSHIP
}

enum WorkModel {
  REMOTE
  HYBRID
  ONSITE
}

enum SalaryType {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum JobStatus {
  DRAFT
  PUBLISHED
  PAUSED
  CLOSED
  ARCHIVED
}

enum CandidateStatus {
  SOURCED
  APPLIED
  SCREENING
  INTERVIEWING
  DISC_TEST
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
  NO_RESPONSE
}

enum ResponseStatus {
  INTERESTED
  NOT_INTERESTED
  NO_RESPONSE
}

enum InterviewStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum InterviewType {
  SCREENING
  TECHNICAL
  BEHAVIORAL
  CULTURAL
  FINAL
  PHONE
  VIDEO
  ONSITE
}

enum NoteType {
  GENERAL
  INTERVIEW
  FEEDBACK
  AI_INSIGHT
}

enum DISCStatus {
  PENDING
  SENT
  STARTED
  COMPLETED
  EXPIRED
}

// ============================================
// CLIENT TRACKING ENUMS
// ============================================

enum NotifyFrequency {
  IMMEDIATE
  DAILY_DIGEST
  WEEKLY_DIGEST
}

enum NotifyChannel {
  EMAIL
  WHATSAPP
  BOTH
}

enum TrackingEventType {
  CANDIDATE_NEW
  CANDIDATE_SCREENING
  CANDIDATE_INTERVIEW
  CANDIDATE_OFFER
  CANDIDATE_HIRED
  CANDIDATE_REJECTED
  CANDIDATE_WITHDRAWN
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  INTERVIEW_CANCELLED
  INTERVIEW_NO_SHOW
  DISC_TEST_SENT
  DISC_TEST_COMPLETED
  DISC_PROFILE_READY
  JOB_PUBLISHED
  JOB_CLOSED
  JOB_PAUSED
  WEEKLY_SUMMARY
  MANUAL_UPDATE
}

enum TrackingNotifStatus {
  PENDING
  GENERATING
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
}

// ============================================
// MESSAGING OMNICHANNEL SYSTEM
// ============================================

model MessageChannel {
  id           String   @id @default(cuid())
  tenantId     String
  type         ChannelType
  name         String
  config       String?
  isActive     Boolean  @default(true)
  instanceName String?
  instanceId   String?
  webhookUrl   String?
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([tenantId, type])
  @@map("message_channels")
}

model Conversation {
  id                String             @id @default(cuid())
  tenantId          String
  candidateId       String
  jobId             String?
  channelId         String?
  channel           ChannelType        @default(CHAT)
  externalId        String?
  status            ConversationStatus @default(ACTIVE)
  aiMode            Boolean            @default(true)
  aiStage           String?
  aiContext         String?
  lastMessageAt     DateTime           @default(now())
  lastMessagePreview String?
  unreadCount       Int                @default(0)
  unreadByCandidate Boolean            @default(false)
  needsIntervention Boolean            @default(false)
  interventionReason String?
  collectedData     String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate         Candidate          @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job               Job?               @relation(fields: [jobId], references: [id], onDelete: SetNull)
  channelConfig     MessageChannel?    @relation(fields: [channelId], references: [id], onDelete: SetNull)
  messages          Message[]
  interventions     HumanIntervention[]

  @@unique([tenantId, candidateId, channel])
  @@index([tenantId, status])
  @@index([tenantId, needsIntervention])
  @@map("conversations")
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  senderType     SenderType
  senderId       String?
  senderName     String?
  content        String
  contentType    ContentType   @default(TEXT)
  mediaUrl       String?
  mediaType      String?
  channel        ChannelType   @default(CHAT)
  externalId     String?
  status         MessageStatus @default(SENT)
  isAiGenerated  Boolean       @default(false)
  aiConfidence   Float?
  needsReview    Boolean       @default(false)
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewNotes    String?
  metadata       String?
  sentAt         DateTime      @default(now())
  deliveredAt    DateTime?
  readAt         DateTime?
  createdAt      DateTime      @default(now())

  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, sentAt])
  @@index([needsReview])
  @@map("messages")
}

model HumanIntervention {
  id              String   @id @default(cuid())
  conversationId  String
  triggeredAt     DateTime @default(now())
  triggeredBy     String?
  reason          String
  resolvedAt      DateTime?
  resolvedBy      String?
  resolutionNotes String?
  createdAt       DateTime @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, resolvedAt])
  @@map("human_interventions")
}

model MessageTemplate {
  id        String      @id @default(cuid())
  tenantId  String
  name      String
  trigger   String
  category  String
  subject   String?
  body      String
  channel   ChannelType @default(CHAT)
  variables String?
  isActive  Boolean     @default(true)
  isDefault Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, trigger, channel])
  @@map("message_templates")
}

