# ============================================
# Zion Recruit - Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================

# --- APP ---
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com

# --- DATABASE (PostgreSQL) ---
DATABASE_URL=postgresql://zion_user:your_db_password@localhost:5432/zion_recruit

# --- AUTH ---
NEXTAUTH_SECRET=generate-with-command-below
NEXTAUTH_URL=https://your-domain.com

# --- ENCRYPTION (AES-256-GCM - 64 chars hex) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- AI PROVIDERS (optional - at least one for AI features) ---
# Using z-ai-web-dev-sdk - no key needed for basic features

# --- STRIPE (optional - for billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_STARTER_PRODUCT_ID=
STRIPE_PROFESSIONAL_PRICE_ID=
STRIPE_PROFESSIONAL_PRODUCT_ID=
STRIPE_ENTERPRISE_PRICE_ID=
STRIPE_ENTERPRISE_PRODUCT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- WHATSAPP / Evolution API (optional) ---
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_URL=

# --- GOOGLE CALENDAR (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- EMAIL (Resend - optional) ---
RESEND_API_KEY=

# --- INTERNAL ---
INTERNAL_SERVICE_TOKEN=generate-a-random-string
