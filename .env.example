# ============================================
# Zion Recruit - Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================

# --- APP ---
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com

# --- DATABASE (PostgreSQL) ---
DATABASE_URL=postgresql://zion_user:your_db_password@localhost:5432/zion_recruit

# --- AUTH ---
NEXTAUTH_SECRET=generate-with-command-below
NEXTAUTH_URL=https://your-domain.com

# --- ENCRYPTION (AES-256-GCM - 64 chars hex) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- AI PROVIDERS (optional - at least one for AI features) ---
# Using z-ai-web-dev-sdk - no key needed for basic features

# --- STRIPE (optional - for billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_STARTER_PRODUCT_ID=
STRIPE_PROFESSIONAL_PRICE_ID=
STRIPE_PROFESSIONAL_PRODUCT_ID=
STRIPE_ENTERPRISE_PRICE_ID=
STRIPE_ENTERPRISE_PRODUCT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- WHATSAPP / Evolution API (optional) ---
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_URL=

# --- GOOGLE CALENDAR (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- EMAIL (Resend - optional) ---
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# --- FILE STORAGE (S3 / Cloudflare R2 / MinIO) ---
# Required for file uploads (resumes, logos, documents)
# If no cloud credentials are set, falls back to local disk (uploads/ directory)

# Option A: Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=zion-recruit
R2_PUBLIC_URL=https://files.your-domain.com
R2_REGION=auto

# Option B: AWS S3 / MinIO
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=            # For R2: https://<account-id>.r2.cloudflarestorage.com
S3_PUBLIC_URL=          # For public access: https://files.your-domain.com
S3_PROVIDER=aws         # 'aws' | 'cloudflare-r2' | 'minio'
S3_FORCE_PATH_STYLE=false  # Set to 'true' for MinIO or self-hosted S3

# --- INTERNAL ---
INTERNAL_SERVICE_TOKEN=generate-a-random-string
